# Copia este archivo como .env y completa los valores reales

# Neon PostgreSQL — copia la connection string desde neon.tech > tu proyecto > Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# Clave secreta para firmar JWT — genera con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_USE_LONG_RANDOM_HEX_STRING
